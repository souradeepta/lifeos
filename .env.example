# LifeOS Environment Variables
# Copy this to .env and fill in values (though defaults work fine for local use)

# Database path (default: db/lifeos.db in project root)
# DATABASE_URL=sqlite+aiosqlite:///db/lifeos.db

# Server
# HOST=0.0.0.0
# PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
